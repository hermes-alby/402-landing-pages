---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Twitter Cascade support is coming soon';
const description = 'This Solana-based service is not yet supported by Alby products.';
---

<BaseLayout title={title} description={description}>
  <section class="panel page">
    <h1>Support for Twitter Cascade is coming soon</h1>
    <p class="lede">
      Twitter Cascade currently uses a Solana payment flow, so it is not supported by Alby products yet.
    </p>
    <p class="lede">
      The service itself looks useful for agents, especially for live tweet search and social research. Once support lands, this page
      can switch from “coming soon” to a direct install or usage flow.
    </p>
  </section>
</BaseLayout>

<style>
  .page {
    padding: 2rem;
  }
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 4vw, 3.1rem);
  }
  .lede {
    color: var(--muted);
    line-height: 1.7;
  }
</style>
