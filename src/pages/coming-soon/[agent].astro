---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { agentsByKey } from '../../data/agents';
import { variants } from '../../data/build-variants';
import { buildPageSeo } from '../../seo-rules';

export function getStaticPaths() {
  return Object.keys(agentsByKey).map((agent) => ({ params: { agent } }));
}

const { agent } = Astro.params;
const currentAgent = agentsByKey[agent ?? ''];
const agentVariants = variants.filter((variant) => variant.agentKey === agent);
const supportedToday = agentVariants.filter((variant) => variant.supportStatus === 'supported');
const installHref = `${import.meta.env.BASE_URL}install/${agent}/`;
const title = `More services for ${currentAgent?.name ?? 'your agent'} are coming soon`;
const description = `Explore services available now for ${currentAgent?.name ?? 'your agent'} and install the Alby Payments Skill.`;
const seo = buildPageSeo({ pathname: Astro.url.pathname, site: Astro.site, pageType: 'coming-soon' });
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: seo.canonical,
};
---

<BaseLayout title={title} description={description} canonical={seo.canonical} robots={seo.robots} schema={schema}>
  <section class="panel page">
    <div class="hero-row">
      {currentAgent && <img class="agent-logo" src={currentAgent.logoSrc} alt={`${currentAgent.name} logo`} />}
      <div>
        <h1>Support for this provider is coming soon</h1>
        <p class="lede">
          Here are some services Alby supports today for {currentAgent?.name ?? 'your agent'} in the meantime.
        </p>
      </div>
    </div>

    <section class="supported-now">
      <div class="section-title-with-icon">
        {currentAgent && <img class="section-agent-logo" src={currentAgent.logoSrc} alt={`${currentAgent.name} logo`} />}
        <h2>Available now for {currentAgent?.name ?? 'your agent'}</h2>
      </div>
      <div class="cards">
        {supportedToday.map((variant) => (
          <a class="card" href={`${import.meta.env.BASE_URL}agents/${variant.agentKey}/${variant.slug}/`}>
            <span class="card-provider-row">
              <img class="card-provider-logo" src={variant.providerLogoSrc} alt={`${variant.providerName} logo`} />
              <strong>{variant.providerName}</strong>
            </span>
            <span>{variant.serviceName}</span>
            <p>{variant.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="capture panel-inner">
      <h2>Want to give your agent access to thousands of more useful services?</h2>
      <a class="button" href={installHref}>Install the Alby Payments Skill</a>
    </section>
  </section>
</BaseLayout>

<style>
  .page {
    padding: 2rem;
    display: grid;
    gap: 1.8rem;
  }
  .hero-row {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .agent-logo {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.1rem);
  }
  .lede, .card p, .card span {
    color: var(--muted);
    line-height: 1.7;
  }
  .supported-now h2,
  .capture h2 {
    margin-bottom: 0.9rem;
  }
  .section-title-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }
  .section-agent-logo {
    width: 30px;
    height: 30px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255,255,255,0.03);
  }
  .section-title-with-icon h2 {
    margin: 0;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .card {
    display: block;
    text-decoration: none;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .card strong {
    color: var(--text);
  }
  .card-provider-row {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.25rem;
  }
  .card-provider-logo {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255,255,255,0.03);
  }
  .panel-inner {
    padding: 1.4rem 1.5rem;
    border-radius: 18px;
    background: rgba(126, 224, 129, 0.08);
    border: 1px solid rgba(126, 224, 129, 0.18);
  }
  .button {
    display: inline-block;
    text-decoration: none;
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
    padding: 0.85rem 1.1rem;
    border-radius: 12px;
    font-weight: 800;
  }
  @media (max-width: 760px) {
    .hero-row {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
