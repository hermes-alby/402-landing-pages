---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdentityLine from '../components/IdentityLine.astro';
import { homepageVariants } from '../data/build-variants';

const title = 'Pay-per-use Agent Services';
const description = 'Explore pay-per-use services your agent can use without sign-up friction.';
---

<BaseLayout title={title} description={description}>
  <section class="hero panel">
    <div>
      <h1>Give your agent useful services without sign-up friction</h1>
      <p class="lede">
        These pages show how OpenClaw, Claude, Codex, and Hermes can use useful paid services without stopping for account
        creation, subscriptions, or other human-only blockers.
      </p>
    </div>
    <div class="callout">
      <strong>Browse service pages</strong>
      <p>
        Jump into a mixed list of real agent × service pages with examples, pricing, and the exact flow your agent can use.
      </p>
    </div>
  </section>

  <section class="service-list">
    <div class="section-header">
      <div>
        <h2>Explore agent-ready service pages</h2>
        <p>
          A shuffled mix of pages so you can scan different services and agents without seeing the homepage grouped into the
          same repeated blocks.
        </p>
      </div>
    </div>

    <div class="grid">
      {homepageVariants.map((variant) => (
        <article class="card panel">
          <IdentityLine
            compact
            agentLogoSrc={variant.agentLogoSrc}
            agentName={variant.agentName}
            providerLogoSrc={variant.providerLogoSrc}
            providerName={variant.providerName}
            title={variant.serviceName}
          />
          <h3>{variant.description}</h3>
          <ul>
            {variant.useCases.slice(0, 2).map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="button" href={`${import.meta.env.BASE_URL}agents/${variant.agentKey}/${variant.slug}/`}>
            Learn more
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 1.02;
  }
  .lede {
    color: var(--muted);
    max-width: 70ch;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .callout {
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .callout p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0.75rem 0 0;
  }
  .service-list {
    margin-top: 2.5rem;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    margin-bottom: 0.35rem;
    font-size: 2rem;
  }
  .section-header p {
    margin-top: 0;
    color: var(--muted);
    max-width: 70ch;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .card {
    padding: 1.5rem;
  }
  h3 {
    margin-bottom: 0.65rem;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6;
  }
  .card ul {
    color: var(--muted);
    line-height: 1.6;
    padding-left: 1.2rem;
    min-height: 5.5rem;
  }
  .button {
    display: inline-block;
    text-decoration: none;
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    font-weight: 700;
  }
  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .section-header {
      flex-direction: column;
    }
  }
</style>
