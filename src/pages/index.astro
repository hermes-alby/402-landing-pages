---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdentityLine from '../components/IdentityLine.astro';
import { agents, homepageVariants, providers, serviceDefinitions } from '../data/build-variants';

const title = 'Pay-per-use Agent Services';
const description = 'Find pay-per-use services for research, content, images, and documents that work with your agent.';

const featuredVariants = homepageVariants.filter((variant) => variant.supportStatus === 'supported').slice(0, 3);
const homepageStats = [
  { value: String(agents.length), label: 'compatible agents' },
  { value: String(providers.length), label: 'providers' },
  { value: String(serviceDefinitions.length), label: 'services' },
  { value: String(homepageVariants.length), label: 'available options' },
];
const categoryHighlights = [...new Set(homepageVariants.map((variant) => variant.category))].slice(0, 5);
---

<BaseLayout title={title} description={description}>
  <section class="hero panel">
    <div>
      <span class="eyebrow">Pay only for the services you use</span>
      <h1>Find pay-per-use services that work with your agent</h1>
      <p class="lede">
        Explore research, content, image, and document services without adding another account, subscription, or setup-heavy
        workflow.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#featured-pages">Explore featured services</a>
        <a class="button secondary" href="#all-service-pages">Browse all services</a>
      </div>
      <dl class="stats" aria-label="Catalog stats">
        {homepageStats.map((stat) => (
          <div class="stat panel-subtle">
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
    </div>
    <div class="callout">
      <strong>Find the right service for your workflow</strong>
      <p>
        Start with featured services to see proven options first, or browse all services to compare providers, pricing, and
        the results each service can deliver.
      </p>
      <div class="category-list" aria-label="Example service categories">
        {categoryHighlights.map((category) => (
          <span class="category-chip">{category}</span>
        ))}
      </div>
    </div>
  </section>

  <section id="featured-pages" class="service-list featured-list">
    <div class="section-header">
      <div>
        <span class="eyebrow">Popular services</span>
        <h2>Featured services</h2>
        <p>Start with a few strong options that show the range of services your agent can use right now.</p>
      </div>
    </div>

    <div class="grid featured-grid">
      {featuredVariants.map((variant) => (
        <article class="card panel feature-card">
          <span class="feature-badge">Featured</span>
          <IdentityLine
            compact
            agentLogoSrc={variant.agentLogoSrc}
            agentName={variant.agentName}
            providerLogoSrc={variant.providerLogoSrc}
            providerName={variant.providerName}
            title={variant.serviceName}
          />
          <p class="card-kicker">{variant.category}</p>
          <h3 class="card-title">{variant.description}</h3>
          <p class="card-meta">{variant.priceLabel} · {variant.paymentLabel}</p>
          <a class="button tertiary" href={`${import.meta.env.BASE_URL}agents/${variant.agentKey}/${variant.slug}/`}>
            View service details
          </a>
        </article>
      ))}
    </div>
  </section>

  <section id="all-service-pages" class="service-list">
    <div class="section-header">
      <div>
        <span class="eyebrow">Full directory</span>
        <h2>Explore agent-ready services</h2>
        <p>
          Browse a mixed selection of services so you can compare providers, pricing, and supported agent workflows in one
          place.
        </p>
      </div>
    </div>

    <div class="grid">
      {homepageVariants.map((variant) => (
        <article class="card panel">
          <IdentityLine
            compact
            agentLogoSrc={variant.agentLogoSrc}
            agentName={variant.agentName}
            providerLogoSrc={variant.providerLogoSrc}
            providerName={variant.providerName}
            title={variant.serviceName}
          />
          <p class="card-kicker">{variant.category}</p>
          <h3 class="card-title">{variant.description}</h3>
          <p class="card-meta">{variant.priceLabel} · {variant.paymentLabel}</p>
          <a class="button secondary card-link" href={`${import.meta.env.BASE_URL}agents/${variant.agentKey}/${variant.slug}/`}>
            Learn more
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 1.02;
  }
  .eyebrow {
    display: inline-flex;
    margin-bottom: 0.9rem;
    color: var(--accent);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .lede {
    color: var(--muted);
    max-width: 70ch;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin: 1.5rem 0;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.85rem;
    margin: 1.5rem 0 0;
  }
  .stat {
    margin: 0;
    padding: 1rem;
    border-radius: 18px;
  }
  .stat dt {
    color: var(--muted);
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }
  .stat dd {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 700;
  }
  .panel-subtle {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .callout {
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .callout p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0.75rem 0 1rem;
  }
  .category-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .category-chip {
    display: inline-flex;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(124, 200, 255, 0.1);
    border: 1px solid rgba(124, 200, 255, 0.16);
    color: var(--accent-2);
    font-size: 0.9rem;
  }
  .service-list {
    margin-top: 3rem;
  }
  .featured-list {
    margin-top: 0;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
  }
  .section-header p {
    margin-top: 0;
    color: var(--muted);
    max-width: 70ch;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .featured-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
  }
  .feature-card {
    background: linear-gradient(180deg, rgba(14, 23, 48, 0.98), rgba(13, 22, 44, 0.92));
    padding: 1.75rem;
  }
  .feature-badge {
    display: inline-flex;
    align-self: flex-start;
    margin-bottom: 0.9rem;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    background: rgba(126, 224, 129, 0.12);
    border: 1px solid rgba(126, 224, 129, 0.22);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .card-kicker {
    margin: 1rem 0 0.45rem;
    color: var(--accent-2);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .card-title {
    margin: 0 0 0.65rem;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 650;
    line-height: 1.45;
  }
  .card-meta {
    margin: 0 0 1.1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .button {
    display: inline-block;
    text-decoration: none;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    font-weight: 700;
  }
  .button.primary,
  .button.tertiary {
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
  }
  .button.secondary {
    border: 1px solid rgba(124, 200, 255, 0.2);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text);
  }
  .card-link {
    align-self: flex-start;
  }
  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .section-header {
      flex-direction: column;
    }
  }
</style>
