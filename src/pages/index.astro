---
import BaseLayout from '../layouts/BaseLayout.astro';
import { serviceSections, variants } from '../data/services';

const title = 'Agent service pages';
const description = 'Explore agent-specific pages for useful services that agents can call on demand.';
---

<BaseLayout title={title} description={description}>
  <section class="hero panel">
    <div>
      <h1>Give your agent useful services without sign-up friction</h1>
      <p class="lede">
        These pages show how OpenClaw, Claude, Codex, and Hermes can use useful paid services without stopping for account
        creation, subscriptions, or other human-only blockers.
      </p>
    </div>
    <div class="callout">
      <strong>What to expect</strong>
      <ul>
        <li>One page per agent × service combination</li>
        <li>Clear examples of the result the service can provide</li>
        <li>Different calls to action depending on whether Alby support exists today</li>
      </ul>
    </div>
  </section>

  {serviceSections.map((section) => {
    const sectionVariants = variants.filter((variant) => variant.serviceKey === section.key);
    return (
      <section class="service-section">
        <div class="section-header">
          <div>
            <h2>{section.title}</h2>
            <p>{section.description}</p>
          </div>
        </div>
        <div class="grid">
          {sectionVariants.map((variant) => (
            <article class="card panel">
              <div class="card-top">
                <div class="agent-badge">
                  <img src={`${import.meta.env.BASE_URL}agents/${variant.agentSlug}.svg`} alt={`${variant.agent} logo`} />
                  <span class="pill">{variant.agent}</span>
                </div>
                <span class="endpoint-tag">{variant.endpointName}</span>
              </div>
              <h3>{variant.title}</h3>
              <p class="tagline">{variant.description}</p>
              <ul>
                {variant.useCases.slice(0, 2).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a class="button" href={`${import.meta.env.BASE_URL}agents/${variant.agentSlug}/${variant.slug}/`}>
                Explore {variant.agent}
              </a>
            </article>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 1.02;
  }
  .lede {
    color: var(--muted);
    max-width: 70ch;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .callout {
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .callout ul {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0;
    padding-left: 1.2rem;
  }
  .service-section {
    margin-top: 2.5rem;
  }
  .section-header h2 {
    margin-bottom: 0.35rem;
    font-size: 2rem;
  }
  .section-header p {
    margin-top: 0;
    color: var(--muted);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .card {
    padding: 1.5rem;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .agent-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .agent-badge img {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .endpoint-tag {
    color: var(--warn);
    font-weight: 600;
  }
  h3 {
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
    line-height: 1.3;
  }
  .tagline {
    margin-top: 0;
    color: var(--muted);
    line-height: 1.6;
  }
  .card ul {
    color: var(--muted);
    line-height: 1.6;
    padding-left: 1.2rem;
    min-height: 5.5rem;
  }
  .button {
    display: inline-block;
    text-decoration: none;
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    font-weight: 700;
  }
  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
