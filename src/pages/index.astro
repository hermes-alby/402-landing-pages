---
import BaseLayout from '../layouts/BaseLayout.astro';
import { endpoint, variants } from '../data/services';

const title = 'Agent service pages';
const description = 'Explore agent-specific pages for using PayPerQ GPT Image 1.5 without sign-up or subscription friction.';
---

<BaseLayout title={title} description={description}>
  <section class="hero panel">
    <div>
      <h1>Give your agent useful services without sign-up friction</h1>
      <p class="lede">
        These pages show how OpenClaw, Claude, Codex, and Hermes can use PayPerQ’s GPT Image 1.5 endpoint to generate great
        results without stopping for account creation, subscriptions, or other human-only blockers.
      </p>
    </div>
    <div class="callout">
      <strong>Current service</strong>
      <dl>
        <div>
          <dt>Provider</dt>
          <dd>{endpoint.serviceName}</dd>
        </div>
        <div>
          <dt>Capability</dt>
          <dd>{endpoint.endpointName}</dd>
        </div>
        <div>
          <dt>Why it matters</dt>
          <dd>{endpoint.paymentLabel}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="grid">
    {variants.map((variant) => (
      <article class="card panel">
        <div class="card-top">
          <div class="agent-badge">
            <img src={`${import.meta.env.BASE_URL}agents/${variant.agentSlug}.svg`} alt={`${variant.agent} logo`} />
            <span class="pill">{variant.agent}</span>
          </div>
          <span class="endpoint-tag">{endpoint.endpointName}</span>
        </div>
        <h2>{variant.title}</h2>
        <p class="tagline">{variant.description}</p>
        <ul>
          {variant.useCases.slice(0, 2).map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <a class="button" href={`${import.meta.env.BASE_URL}agents/${variant.agentSlug}/${variant.slug}/`}>
          Explore {variant.agent}
        </a>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 1.02;
  }
  .lede {
    color: var(--muted);
    max-width: 70ch;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .callout {
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .callout dl {
    display: grid;
    gap: 0.85rem;
    margin: 1rem 0 0;
  }
  .callout dt {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 0.2rem;
  }
  .callout dd {
    margin: 0;
    font-weight: 600;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .card {
    padding: 1.5rem;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .agent-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .agent-badge img {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .endpoint-tag {
    color: var(--warn);
    font-weight: 600;
  }
  h2 {
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
    line-height: 1.3;
  }
  .tagline {
    margin-top: 0;
    color: var(--muted);
    line-height: 1.6;
  }
  .card ul {
    color: var(--muted);
    line-height: 1.6;
    padding-left: 1.2rem;
    min-height: 5.5rem;
  }
  .button {
    display: inline-block;
    text-decoration: none;
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    font-weight: 700;
  }
  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
