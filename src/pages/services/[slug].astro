---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const title = `${service.name} · Mock 402 landing page`;
const description = service.summary;
---

<BaseLayout title={title} description={description}>
  <article class="page">
    <section class="hero panel">
      <div class="hero-main">
        <div class="meta-row">
          <span class="pill">{service.protocol}</span>
          <span class="badge">{service.qualityVerdict}</span>
        </div>
        <h1>{service.name}</h1>
        <p class="tagline">{service.tagline}</p>
        <p class="summary">{service.summary}</p>
        <div class="links">
          <a href={service.website}>Mock website</a>
          <a href={service.docs}>Mock docs</a>
        </div>
      </div>
      <aside class="score-card">
        <div>
          <small>Mock quality score</small>
          <strong>{service.score.toFixed(1)} / 10</strong>
        </div>
        <div>
          <small>Category</small>
          <strong>{service.category}</strong>
        </div>
        <div>
          <small>Mock price</small>
          <strong>{service.price}</strong>
        </div>
      </aside>
    </section>

    <section class="content-grid">
      <section class="panel section">
        <h2>Why this service made the prototype list</h2>
        <ul>
          {service.whyListed.map((reason) => (
            <li>{reason}</li>
          ))}
        </ul>
      </section>

      <section class="panel section">
        <h2>Example use cases</h2>
        <ul>
          {service.useCases.map((useCase) => (
            <li>{useCase}</li>
          ))}
        </ul>
      </section>
    </section>

    <section class="panel section faq">
      <h2>FAQ</h2>
      {service.faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>

    <p class="back-link">
      <a href={`${import.meta.env.BASE_URL}`}>← Back to index</a>
    </p>
  </article>
</BaseLayout>

<style>
  .page {
    display: grid;
    gap: 1.5rem;
  }
  .hero {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
  }
  .hero-main h1 {
    margin: 0.5rem 0;
    font-size: clamp(2rem, 4vw, 3.3rem);
  }
  .meta-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .badge {
    color: var(--warn);
    font-weight: 700;
  }
  .tagline {
    font-size: 1.2rem;
    margin: 0;
  }
  .summary {
    color: var(--muted);
    line-height: 1.7;
    max-width: 70ch;
  }
  .links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }
  .score-card {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .score-card small {
    display: block;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .score-card strong {
    font-size: 1.15rem;
  }
  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .section {
    padding: 1.5rem 1.75rem;
  }
  .section ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .faq details {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem 0;
  }
  .faq details:first-of-type {
    border-top: 0;
    padding-top: 0.25rem;
  }
  .faq summary {
    cursor: pointer;
    font-weight: 700;
  }
  .faq p {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0;
  }
  .back-link {
    margin: 0;
  }
  @media (max-width: 820px) {
    .hero, .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
