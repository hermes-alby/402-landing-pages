---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ActionCta from '../../../components/ActionCta.astro';
import IdentityLine from '../../../components/IdentityLine.astro';
import { variants } from '../../../data/build-variants';
import { buildPageSeo } from '../../../seo-rules';

export function getStaticPaths() {
  return variants.map((variant) => ({
    params: { agent: variant.agentKey, slug: variant.slug },
    props: { variant },
  }));
}

const { variant } = Astro.props;
const title = variant.title;
const description = variant.description;
const relatedVariants = variants.filter((item) => item.agentKey === variant.agentKey && item.slug !== variant.slug).slice(0, 3);
const seo = buildPageSeo({
  pathname: Astro.url.pathname,
  site: Astro.site,
  pageType: 'service',
  supportStatus: variant.supportStatus,
});
const ogImage =
  variant.exampleOutput.kind === 'image'
    ? new URL(variant.exampleOutput.imageSrc, Astro.site).toString()
    : new URL(variant.providerLogoSrc, Astro.site).toString();
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: new URL(import.meta.env.BASE_URL, Astro.site).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: seo.canonical,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description,
    url: seo.canonical,
    provider: {
      '@type': 'Organization',
      name: variant.providerName,
    },
    areaServed: 'Worldwide',
    category: variant.category,
    offers: {
      '@type': 'Offer',
      priceCurrency: 'USD',
      description: variant.priceLabel,
      availability: variant.supportStatus === 'supported' ? 'https://schema.org/InStock' : 'https://schema.org/PreOrder',
      url: seo.canonical,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: variant.faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title={title} description={description} canonical={seo.canonical} robots={seo.robots} ogImage={ogImage} schema={schema}>
  <article class="page">
    <section class="hero panel">
      <div class="hero-main">
        <IdentityLine
          agentLogoSrc={variant.agentLogoSrc}
          agentName={variant.agentName}
          providerLogoSrc={variant.providerLogoSrc}
          providerName={variant.providerName}
          title={variant.title}
        />
        <h1>{variant.description}</h1>
        <p class="summary">{variant.heroSummary}</p>
        <ul class="hero-points">
          {variant.heroBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <ActionCta {...variant.cta} />
      </div>
      <aside class="hero-aside">
        <div>
          <small>Result</small>
          <strong>{variant.resultLabel}</strong>
        </div>
        <div>
          <small>Category</small>
          <strong>{variant.category}</strong>
        </div>
        <div>
          <small>Cost</small>
          <strong>{variant.priceLabel}</strong>
        </div>
      </aside>
    </section>

    <section class="panel section">
      <div class="section-head">
        <div>
          <p class="eyebrow">{variant.exampleOutput.title}</p>
          <h2>See the kind of result {variant.agentName} can get from {variant.providerName}</h2>
        </div>
      </div>
      <div class:list={["example-grid", variant.exampleOutput.kind === 'table' && 'table-layout']}>
        {variant.exampleOutput.kind === 'image' ? (
          <figure class="example-card">
            <img src={variant.exampleOutput.imageSrc} alt={variant.exampleOutput.imageAlt} />
            <figcaption>{variant.exampleOutput.caption}</figcaption>
            {variant.exampleOutput.supportingImages?.length ? (
              <div class="supporting-gallery">
                {variant.exampleOutput.supportingImages.map((image) => (
                  <figure class="supporting-card">
                    <img src={image.src} alt={image.alt} />
                    {image.caption ? <figcaption>{image.caption}</figcaption> : null}
                  </figure>
                ))}
              </div>
            ) : null}
          </figure>
        ) : (
          <div class="table-card">
            <p class="table-caption">{variant.exampleOutput.caption}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    {variant.exampleOutput.columns.map((column) => (
                      <th>{column}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {variant.exampleOutput.rows.map((row) => (
                    <tr>
                      {row.map((cell) => (
                        <td>{cell}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
        <div class="output-meta">
          {variant.examplePrompt && (
            <>
              <h3>{variant.examplePromptHeading ?? 'Example prompt'}</h3>
              <p class="prompt-copy">{variant.examplePrompt}</p>
            </>
          )}
          {variant.exampleOutput.briefingParagraphs?.length ? (
            <div class="briefing-card">
              <h3>{variant.exampleOutput.briefingTitle ?? 'Example briefing'}</h3>
              {variant.exampleOutput.briefingParagraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          ) : null}
          <ul>
            {variant.exampleOutput.details.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Use cases</p>
      <h2>What {variant.agentName} can do with this service</h2>
      <div class="cards">
        {variant.useCases.map((useCase) => (
          <article class="mini-card">
            <h3>{useCase}</h3>
            <p>Use {variant.providerName} {variant.serviceName} on demand inside a broader {variant.agentName} workflow.</p>
          </article>
        ))}
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Why this works</p>
      <h2>{variant.whyItWorksTitle}</h2>
      <ul class="bullet-list">
        {variant.whyItWorks.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section faq">
      <p class="eyebrow">FAQ</p>
      <h2>What people usually need to know before trying this</h2>
      {variant.faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section related">
      <div class="eyebrow-with-icon">
        <img src={variant.agentLogoSrc} alt={`${variant.agentName} logo`} />
        <p class="eyebrow">More for {variant.agentName}</p>
      </div>
      <h2>Explore more amazing services</h2>
      <div class="related-links">
        {relatedVariants.map((item) => (
          <a class="related-link" href={`${import.meta.env.BASE_URL}agents/${item.agentKey}/${item.slug}/`}>
            <span class="related-provider">
              <img src={item.providerLogoSrc} alt={`${item.providerName} logo`} />
              <strong>{item.providerName}</strong>
            </span>
            <span>{item.serviceName}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page {
    display: grid;
    gap: 1.5rem;
  }
  .hero {
    display: grid;
    grid-template-columns: 1.7fr 0.9fr;
    gap: 1.5rem;
    padding: 2rem;
  }
  .hero-main h1 {
    margin: 0.6rem 0;
    color: var(--muted);
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 500;
    line-height: 1.6;
    max-width: 70ch;
  }
  .summary {
    color: var(--muted);
    line-height: 1.7;
    max-width: 70ch;
  }
  .hero-points {
    margin: 1.2rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .hero-aside {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hero-aside small {
    display: block;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .hero-aside strong {
    font-size: 1.05rem;
  }
  .section {
    padding: 1.7rem;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: var(--warn);
    margin-bottom: 0.4rem;
  }
  .eyebrow-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
  }
  .eyebrow-with-icon img {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255, 255, 255, 0.03);
  }
  .eyebrow-with-icon .eyebrow {
    margin: 0;
  }
  .example-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.25rem;
    align-items: start;
  }
  .example-grid.table-layout {
    grid-template-columns: 1.4fr 0.8fr;
  }
  .example-card,
  .table-card,
  .mini-card,
  details,
  .related-link {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .example-card {
    margin: 0;
    overflow: hidden;
  }
  .example-card img {
    display: block;
    width: 100%;
    height: auto;
  }
  .supporting-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1rem;
  }
  .supporting-card {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .supporting-card img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  .supporting-card figcaption {
    padding: 0.75rem 0.85rem;
    color: var(--muted);
    line-height: 1.55;
    font-size: 0.94rem;
  }
  .example-card figcaption,
  .table-caption,
  .output-meta,
  .briefing-card p,
  details p,
  .related-link span,
  .mini-card p {
    color: var(--muted);
    line-height: 1.7;
  }
  .example-card figcaption,
  .table-card,
  .output-meta,
  .mini-card,
  details,
  .related-link {
    padding: 1rem 1.1rem;
  }
  .table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th,
  td {
    text-align: left;
    padding: 0.7rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    vertical-align: top;
  }
  .prompt-copy {
    color: var(--muted);
    line-height: 1.7;
  }
  .briefing-card {
    margin: 1.2rem 0;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    background: rgba(124, 200, 255, 0.08);
    border: 1px solid rgba(124, 200, 255, 0.14);
  }
  .briefing-card h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }
  .output-meta ul,
  .bullet-list {
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .cards,
  .related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .related-link {
    display: block;
    text-decoration: none;
    color: var(--text);
  }
  .related-provider {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.35rem;
  }
  .related-provider img {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255, 255, 255, 0.03);
  }
  summary {
    cursor: pointer;
    font-weight: 700;
  }
  @media (max-width: 920px) {
    .hero,
    .example-grid,
    .example-grid.table-layout {
      grid-template-columns: 1fr;
    }
    .supporting-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
