---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ActionCta from '../../../components/ActionCta.astro';
import { variants } from '../../../data/services';

export function getStaticPaths() {
  return variants.map((variant) => ({
    params: { agent: variant.agentSlug, slug: variant.slug },
    props: { variant },
  }));
}

const { variant } = Astro.props;
const title = variant.title;
const description = variant.description;
const agentLogo = `${import.meta.env.BASE_URL}agents/${variant.agentSlug}.svg`;
const relatedVariants = variants.filter((item) => item.agentSlug === variant.agentSlug && item.slug !== variant.slug).slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <article class="page">
    <section class="hero panel">
      <div class="hero-main">
        <div class="meta-row">
          <img class="agent-logo" src={agentLogo} alt={`${variant.agent} logo`} />
          <span class="pill">{variant.agent}</span>
          <span class="service-pill">{variant.serviceName} · {variant.endpointName}</span>
        </div>
        <h1>{variant.title}</h1>
        <p class="tagline">{variant.description}</p>
        <p class="summary">{variant.heroSummary}</p>
        <ul class="hero-points">
          {variant.heroBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <ActionCta {...variant.cta} />
      </div>
      <aside class="hero-aside">
        <div>
          <small>Result</small>
          <strong>{variant.resultLabel}</strong>
        </div>
        <div>
          <small>Category</small>
          <strong>{variant.category}</strong>
        </div>
        <div>
          <small>Cost</small>
          <strong>{variant.priceLabel}</strong>
        </div>
      </aside>
    </section>

    <section class="panel section">
      <div class="section-head">
        <div>
          <p class="eyebrow">{variant.exampleOutput.title}</p>
          <h2>See the kind of result {variant.agent} can get from {variant.serviceName}</h2>
        </div>
      </div>
      <div class:list={["example-grid", variant.exampleOutput.kind === 'table' && 'table-layout']}>
        {variant.exampleOutput.kind === 'image' ? (
          <figure class="example-card">
            <img src={variant.exampleOutput.imageSrc} alt={variant.exampleOutput.imageAlt} />
            <figcaption>{variant.exampleOutput.caption}</figcaption>
          </figure>
        ) : (
          <div class="table-card">
            <p class="table-caption">{variant.exampleOutput.caption}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    {variant.exampleOutput.columns.map((column) => (
                      <th>{column}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {variant.exampleOutput.rows.map((row) => (
                    <tr>
                      <td>{row.author}</td>
                      <td>{row.tweet}</td>
                      <td>{row.likes}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
        <div class="output-meta">
          {variant.examplePrompt && (
            <>
              <h3>{variant.examplePromptHeading ?? 'Example prompt'}</h3>
              <p class="prompt-copy">{variant.examplePrompt}</p>
            </>
          )}
          <ul>
            {variant.exampleOutput.details.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Use cases</p>
      <h2>What {variant.agent} can do with this service</h2>
      <div class="cards">
        {variant.useCases.map((useCase) => (
          <article class="mini-card">
            <h3>{useCase}</h3>
            <p>Use {variant.serviceName} on demand inside a broader {variant.agent} workflow.</p>
          </article>
        ))}
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Why this works</p>
      <h2>{variant.whyItWorksTitle}</h2>
      <ul class="bullet-list">
        {variant.whyItWorks.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section faq">
      <p class="eyebrow">FAQ</p>
      <h2>What people usually need to know before trying this</h2>
      {variant.faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section related">
      <p class="eyebrow">More for {variant.agent}</p>
      <h2>Explore more amazing services</h2>
      <div class="related-links">
        {relatedVariants.map((item) => (
          <a class="related-link" href={`${import.meta.env.BASE_URL}agents/${item.agentSlug}/${item.slug}/`}>
            <strong>{item.serviceName}</strong>
            <span>{item.endpointName}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page {
    display: grid;
    gap: 1.5rem;
  }
  .hero {
    display: grid;
    grid-template-columns: 1.7fr 0.9fr;
    gap: 1.5rem;
    padding: 2rem;
  }
  .hero-main h1 {
    margin: 0.6rem 0;
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    line-height: 1.05;
  }
  .meta-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .agent-logo {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: var(--shadow);
  }
  .service-pill {
    color: var(--warn);
    font-weight: 700;
  }
  .tagline {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.55;
  }
  .summary {
    color: var(--muted);
    line-height: 1.7;
    max-width: 70ch;
  }
  .hero-points {
    margin: 1.2rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .hero-aside {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hero-aside small {
    display: block;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }
  .hero-aside strong {
    font-size: 1.06rem;
  }
  .section {
    padding: 1.6rem 1.8rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .section h2 {
    margin-top: 0;
    font-size: 1.8rem;
  }
  .example-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1.35rem;
    align-items: start;
  }
  .example-grid.table-layout {
    grid-template-columns: 1.35fr 0.85fr;
  }
  .example-card {
    margin: 0;
  }
  .example-card img {
    width: 100%;
    display: block;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .example-card figcaption,
  .output-meta,
  .mini-card p,
  .faq p,
  .bullet-list,
  .output-meta ul,
  .table-caption,
  td,
  th {
    color: var(--muted);
    line-height: 1.7;
  }
  .table-card {
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255, 255, 255, 0.03);
    padding: 1rem;
  }
  .table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  th, td {
    text-align: left;
    padding: 0.8rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    vertical-align: top;
  }
  .output-meta h3,
  .mini-card h3 {
    margin-top: 0;
  }
  .prompt-copy {
    padding: 1rem;
    border-radius: 16px;
    background: rgba(124, 200, 255, 0.08);
    border: 1px solid rgba(124, 200, 255, 0.14);
  }
  .prompt-copy.muted {
    color: var(--muted);
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .mini-card {
    padding: 1.2rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .bullet-list {
    padding-left: 1.2rem;
    margin-bottom: 0;
  }
  .faq details {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem 0;
  }
  .faq details:first-of-type {
    border-top: 0;
    padding-top: 0.2rem;
  }
  .faq summary {
    cursor: pointer;
    font-weight: 700;
  }
  .related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .related-link {
    display: block;
    text-decoration: none;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .related-link strong {
    display: block;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  .related-link span {
    color: var(--muted);
  }
  @media (max-width: 920px) {
    .hero,
    .example-grid,
    .example-grid.table-layout,
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
