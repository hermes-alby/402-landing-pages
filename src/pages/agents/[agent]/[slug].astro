---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ActionCta from '../../../components/ActionCta.astro';
import IdentityLine from '../../../components/IdentityLine.astro';
import { variants } from '../../../data/build-variants';

export function getStaticPaths() {
  return variants.map((variant) => ({
    params: { agent: variant.agentKey, slug: variant.slug },
    props: { variant },
  }));
}

const { variant } = Astro.props;
const title = variant.title;
const description = variant.description;
const relatedVariants = variants.filter((item) => item.agentKey === variant.agentKey && item.slug !== variant.slug).slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <article class="page">
    <section class="hero panel">
      <div class="hero-main">
        <IdentityLine
          agentLogoSrc={variant.agentLogoSrc}
          agentName={variant.agentName}
          providerLogoSrc={variant.providerLogoSrc}
          providerName={variant.providerName}
          title={variant.title}
        />
        <h1>{variant.description}</h1>
        <p class="summary">{variant.heroSummary}</p>
        <ul class="hero-points">
          {variant.heroBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <ActionCta {...variant.cta} />
      </div>
      <aside class="hero-aside">
        <div>
          <small>Result</small>
          <strong>{variant.resultLabel}</strong>
        </div>
        <div>
          <small>Category</small>
          <strong>{variant.category}</strong>
        </div>
        <div>
          <small>Cost</small>
          <strong>{variant.priceLabel}</strong>
        </div>
      </aside>
    </section>

    <section class="panel section">
      <div class="section-head">
        <div>
          <p class="eyebrow">{variant.exampleOutput.title}</p>
          <h2>See the kind of result {variant.agentName} can get from {variant.providerName}</h2>
        </div>
      </div>
      <div class:list={["example-grid", variant.exampleOutput.kind === 'table' && 'table-layout']}>
        {variant.exampleOutput.kind === 'image' ? (
          <figure class="example-card">
            <img src={variant.exampleOutput.imageSrc} alt={variant.exampleOutput.imageAlt} />
            <figcaption>{variant.exampleOutput.caption}</figcaption>
          </figure>
        ) : (
          <div class="table-card">
            <p class="table-caption">{variant.exampleOutput.caption}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    {variant.exampleOutput.columns.map((column) => (
                      <th>{column}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {variant.exampleOutput.rows.map((row) => (
                    <tr>
                      {row.map((cell) => (
                        <td>{cell}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
        <div class="output-meta">
          {variant.examplePrompt && (
            <>
              <h3>{variant.examplePromptHeading ?? 'Example prompt'}</h3>
              <p class="prompt-copy">{variant.examplePrompt}</p>
            </>
          )}
          {variant.exampleOutput.briefingParagraphs?.length ? (
            <div class="briefing-card">
              <h3>{variant.exampleOutput.briefingTitle ?? 'Example briefing'}</h3>
              {variant.exampleOutput.briefingParagraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          ) : null}
          <ul>
            {variant.exampleOutput.details.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Use cases</p>
      <h2>What {variant.agentName} can do with this service</h2>
      <div class="cards">
        {variant.useCases.map((useCase) => (
          <article class="mini-card">
            <h3>{useCase}</h3>
            <p>Use {variant.providerName} {variant.serviceName} on demand inside a broader {variant.agentName} workflow.</p>
          </article>
        ))}
      </div>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section">
      <p class="eyebrow">Why this works</p>
      <h2>{variant.whyItWorksTitle}</h2>
      <ul class="bullet-list">
        {variant.whyItWorks.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section faq">
      <p class="eyebrow">FAQ</p>
      <h2>What people usually need to know before trying this</h2>
      {variant.faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
      <ActionCta {...variant.cta} compact />
    </section>

    <section class="panel section related">
      <p class="eyebrow">More for {variant.agentName}</p>
      <h2>Explore more amazing services</h2>
      <div class="related-links">
        {relatedVariants.map((item) => (
          <a class="related-link" href={`${import.meta.env.BASE_URL}agents/${item.agentKey}/${item.slug}/`}>
            <strong>{item.providerName}</strong>
            <span>{item.serviceName}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .page {
    display: grid;
    gap: 1.5rem;
  }
  .hero {
    display: grid;
    grid-template-columns: 1.7fr 0.9fr;
    gap: 1.5rem;
    padding: 2rem;
  }
  .hero-main h1 {
    margin: 0.6rem 0;
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    line-height: 1.05;
  }
  .summary {
    color: var(--muted);
    line-height: 1.7;
    max-width: 70ch;
  }
  .hero-points {
    margin: 1.2rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .hero-aside {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hero-aside small {
    display: block;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .hero-aside strong {
    font-size: 1.05rem;
  }
  .section {
    padding: 1.7rem;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: var(--warn);
    margin-bottom: 0.4rem;
  }
  .example-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.25rem;
    align-items: start;
  }
  .example-grid.table-layout {
    grid-template-columns: 1.4fr 0.8fr;
  }
  .example-card,
  .table-card,
  .mini-card,
  details,
  .related-link {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .example-card {
    margin: 0;
    overflow: hidden;
  }
  .example-card img {
    display: block;
    width: 100%;
    height: auto;
  }
  .example-card figcaption,
  .table-caption,
  .output-meta,
  .briefing-card p,
  details p,
  .related-link span,
  .mini-card p {
    color: var(--muted);
    line-height: 1.7;
  }
  .example-card figcaption,
  .table-card,
  .output-meta,
  .mini-card,
  details,
  .related-link {
    padding: 1rem 1.1rem;
  }
  .table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th,
  td {
    text-align: left;
    padding: 0.7rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    vertical-align: top;
  }
  .prompt-copy {
    color: var(--muted);
    line-height: 1.7;
  }
  .briefing-card {
    margin: 1.2rem 0;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    background: rgba(124, 200, 255, 0.08);
    border: 1px solid rgba(124, 200, 255, 0.14);
  }
  .briefing-card h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }
  .output-meta ul,
  .bullet-list {
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .cards,
  .related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .related-link {
    display: block;
    text-decoration: none;
    color: var(--text);
  }
  summary {
    cursor: pointer;
    font-weight: 700;
  }
  @media (max-width: 920px) {
    .hero,
    .example-grid,
    .example-grid.table-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
