---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Install the Alby Payments Skill';
const description = 'Placeholder install page for the Alby Payments Skill used by supported service pages.';
---

<BaseLayout title={title} description={description}>
  <section class="panel install-page">
    <h1>Install the Alby Payments Skill</h1>
    <p class="lede">
      This is a placeholder destination for services that Alby products can support. In the real flow, this page would explain how
      to install the skill and start using compatible services with your agent.
    </p>
  </section>
</BaseLayout>

<style>
  .install-page {
    padding: 2rem;
  }
  h1 {
    margin-top: 0;
    font-size: clamp(2rem, 4vw, 3.1rem);
  }
  .lede {
    color: var(--muted);
    line-height: 1.7;
  }
</style>
