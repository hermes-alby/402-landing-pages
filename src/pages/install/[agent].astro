---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { agentsByKey } from '../../data/agents';
import { installFlows } from '../../data/install-flows';
import { variants } from '../../data/build-variants';
import { buildPageSeo } from '../../seo-rules';

export function getStaticPaths() {
  return Object.keys(agentsByKey).map((agent) => ({ params: { agent } }));
}

const { agent } = Astro.params;
const currentAgent = agentsByKey[agent ?? ''];
const installFlow = installFlows[agent ?? ''];
const agentVariants = variants.filter((variant) => variant.agentKey === agent);
const supportedToday = agentVariants.filter((variant) => variant.supportStatus === 'supported');
const title = `Install the Alby Payments Skill for ${currentAgent?.name ?? 'your agent'}`;
const description = `Install the Alby Payments Skill for ${currentAgent?.name ?? 'your agent'} and unlock supported services.`;
const seo = buildPageSeo({ pathname: Astro.url.pathname, site: Astro.site, pageType: 'install' });
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: seo.canonical,
};
---

<BaseLayout title={title} description={description} canonical={seo.canonical} robots={seo.robots} schema={schema}>
  <section class="panel install-page">
    <div class="hero-row">
      {currentAgent && <img class="agent-logo" src={currentAgent.logoSrc} alt={`${currentAgent.name} logo`} />}
      <div>
        <h1>Install the Alby Payments Skill for {currentAgent?.name ?? 'your agent'}</h1>
        <p class="lede">
          Give {currentAgent?.name ?? 'your agent'} access to useful services without sign-up, email, or subscription friction.
        </p>
      </div>
    </div>

    <section class="panel-inner">
      <h2>Install instructions for {currentAgent?.name ?? 'your agent'}</h2>
      {installFlow?.kind === 'prompt' ? (
        <pre class="command-block"><code>{installFlow.prompt}</code></pre>
      ) : (
        <pre class="command-block"><code>{installFlow?.command ?? 'npx skills add getAlby/payments-skill'}</code></pre>
      )}
    </section>

    <section class="supported-now">
      <div class="section-title-with-icon">
        {currentAgent && <img class="section-agent-logo" src={currentAgent.logoSrc} alt={`${currentAgent.name} logo`} />}
        <h2>Available now for {currentAgent?.name ?? 'your agent'}</h2>
      </div>
      <div class="cards">
        {supportedToday.map((variant) => (
          <a class="card" href={`${import.meta.env.BASE_URL}agents/${variant.agentKey}/${variant.slug}/`}>
            <span class="card-provider-row">
              <img class="card-provider-logo" src={variant.providerLogoSrc} alt={`${variant.providerName} logo`} />
              <strong>{variant.providerName}</strong>
            </span>
            <span>{variant.serviceName}</span>
            <p>{variant.description}</p>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .install-page {
    padding: 2rem;
    display: grid;
    gap: 1.8rem;
  }
  .hero-row {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .agent-logo {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.1rem);
  }
  .lede,
  .card p,
  .card span {
    color: var(--muted);
    line-height: 1.7;
  }
  .panel-inner {
    padding: 1.4rem 1.5rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .command-block {
    margin: 0;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    background: rgba(124, 200, 255, 0.08);
    border: 1px solid rgba(124, 200, 255, 0.14);
    color: var(--text);
    overflow-x: auto;
  }
  .command-block code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.95rem;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .supported-now h2,
  .capture h2 {
    margin-bottom: 0.9rem;
  }
  .section-title-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }
  .section-agent-logo {
    width: 30px;
    height: 30px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255,255,255,0.03);
  }
  .section-title-with-icon h2 {
    margin: 0;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .card {
    display: block;
    text-decoration: none;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .card strong {
    color: var(--text);
  }
  .card-provider-row {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.25rem;
  }
  .card-provider-logo {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.08);
    object-fit: contain;
    background: rgba(255,255,255,0.03);
  }
  @media (max-width: 760px) {
    .hero-row {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
