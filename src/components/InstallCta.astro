---
export interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const installHref = `${import.meta.env.BASE_URL}install/`;
---

<div class:list={["cta-box", compact && "compact"]}>
  <div>
    <strong>Install the Alby Payments Skill</strong>
    <p>Gives your agent access to useful services without sign-up.</p>
  </div>
  <a class="cta-button" href={installHref}>Install now</a>
</div>

<style>
  .cta-box {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.1rem;
    margin-top: 1.25rem;
    border-radius: 18px;
    background: rgba(126, 224, 129, 0.08);
    border: 1px solid rgba(126, 224, 129, 0.18);
  }
  .cta-box p {
    margin: 0.35rem 0 0;
    color: var(--muted);
  }
  .cta-box.compact {
    padding: 0.9rem 1rem;
  }
  .cta-button {
    display: inline-block;
    white-space: nowrap;
    text-decoration: none;
    background: linear-gradient(90deg, var(--accent), #9af7c8);
    color: #08111f;
    padding: 0.82rem 1rem;
    border-radius: 12px;
    font-weight: 800;
  }
  @media (max-width: 720px) {
    .cta-box {
      flex-direction: column;
      align-items: stretch;
    }
    .cta-button {
      text-align: center;
    }
  }
</style>
